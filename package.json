{
  "name": "@rovidev/webhooks-engine",
  "version": "1.0.0",
  "description": "Idempotent webhook processing: signature verification, deduplication, retries with backoff and dead-letter queue.",
  "license": "MIT",
  "author": "RoviDev (https://rovidev.com)",
  "homepage": "https://rovidev.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/rovidev95/rovidev-webhooks-engine.git"
  },
  "keywords": [
    "webhooks",
    "idempotency",
    "stripe",
    "retry",
    "exponential-backoff",
    "dead-letter-queue",
    "hmac",
    "typescript",
    "redis"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts",
    "example": "tsx examples/express-server.ts"
  },
  "peerDependencies": {
    "ioredis": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "express": "^5.0.1",
    "ioredis": "^5.4.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
